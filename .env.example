# Vault — bootstrap token for dev mode
VAULT_TOKEN=dev-root-token

# Bootstrap-only secrets — used by docker-compose to initialise postgres and MinIO.
# The api container never receives these; it fetches them from Vault at startup.
DB_PASSWORD=changeme
MINIO_ROOT_PASSWORD=changeme

# Port overrides (optional — defaults shown)
API_PORT=8000
MODEL_SERVER_PORT=8001
CHATBOT_PORT=8501
WIDGET_PORT=3000
HOST_PORT=8080
VAULT_PORT=8200
DB_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
