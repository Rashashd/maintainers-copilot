# Vault
VAULT_DEV_ROOT_TOKEN=dev-root-token

# Infra bootstrapping (Postgres + MinIO need these before Vault is up)
# These are the ONLY secrets in this file. seed.sh reads them and writes them
# into Vault so the app always reads from Vault at runtime, not from env vars.
DB_PASSWORD=
MINIO_ROOT_PASSWORD=

# Port overrides (optional — defaults shown)
API_PORT=8000
MODEL_SERVER_PORT=8001
CHATBOT_PORT=8501
WIDGET_PORT=3000
HOST_PORT=8080
VAULT_PORT=8200
DB_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
